{
  "name": "react-native-tour-guide",
  "version": "1.0.0",
  "description": "Interactive step-by-step tour guide for React Native apps, based on rn-tourguide",
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "private": false,
  "scripts": {
    "test": "TZ=Europe/Paris jest --no-watchman",
    "tsc": "node_modules/.bin/tsc --noEmit",
    "tsc:watch": "node_modules/.bin/tsc --noEmit --watch",
    "build": "rm -rf lib/ && node_modules/.bin/tsc",
    "lint": "tslint --project .",
    "verify": "yarn test && yarn lint && yarn tsc && yarn build",
    "prepublishOnly": "yarn verify",
    "cleaning": "rm -rf node_modules && rm -f yarn.lock && yarn cache clean && yarn install && watchman watch-del-all && rm -fr $TMPDIR/react-*"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ernestbies/react-native-tour-guide.git"
  },
  "keywords": [
    "react-native",
    "react-native-tour-guide",
    "react-native-tour",
    "react-native-onboarding",
    "react-native-walkthrough",
    "react-native-copilot",
    "mobile-app-tour-guide",
    "tour-guide",
    "app-tour",
    "app-onboarding",
    "product-tour",
    "walkthrough",
    "guided-tour",
    "tooltip",
    "overlay",
    "intro",
    "copilot",
    "rn-tourguide"
  ],
  "author": "ernestbies",
  "license": "MIT",
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/lodash.clamp": "^4.0.9",
    "@types/react": "^19.2.14",
    "@babel/core": "^7.29.0",
    "jest": "^29.7.0",
    "react": "^19.2.6",
    "react-native": "^0.85.3",
    "react-native-svg": "^15.15.5",
    "react-test-renderer": "^19.2.6",
    "ts-jest": "^29.4.9",
    "tslint": "^6.1.3",
    "tslint-config-prettier": "^1.18.0",
    "typescript": "^6.0.3"
  },
  "jest": {
    "testEnvironment": "node",
    "transform": {
      "^.+\\.tsx?$": [
        "ts-jest",
        {
          "tsconfig": {
            "types": [
              "jest"
            ]
          }
        }
      ]
    },
    "globals": {
      "__TEST__": true
    }
  },
  "dependencies": {
    "flubber": "^0.4.2",
    "lodash.clamp": "^4.0.3",
    "memoize-one": "^6.0.0",
    "mitt": "^3.0.1"
  },
  "peerDependencies": {
    "react": ">=17",
    "react-native": ">=0.64",
    "react-native-svg": ">=12.3.0"
  }
}
